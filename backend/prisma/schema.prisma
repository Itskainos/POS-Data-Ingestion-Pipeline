// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-py"
  recursive_type_depth = 5
}

datasource db {
  provider = "postgresql"
  // Set the DATABASE_URL in your .env file.
  // Neon Connection String Example: postgresql://USER:PASSWORD@EP-HOST-NAME.region.aws.neon.tech/neondb?sslmode=require
  url      = env("DATABASE_URL")
}

/// Stores every raw POS XML upload alongside its parsed JSON representation.
model POSDataRecord {
  /// UUID primary key — generated by the database.
  id          String   @id @default(uuid())

  /// Identifies which POS system sent the data (defaults to "POS").
  source      String   @default("POS")

  /// The original, unmodified XML payload as a string.
  raw_xml     String

  /// The parsed representation of the XML, stored as a flexible JSON blob.
  parsed_data Json

  /// The type of message (e.g., NAXML-ItemMaintenanceRequest).
  message_type String?

  /// Timestamp of when this record was inserted.
  created_at  DateTime @default(now())

  @@map("pos_data_records")
}

/// Represents a product item in the catalog.
model Item {
  /// UUID primary key.
  id              String   @id @default(uuid())

  /// Unique code for the item (e.g., SKU or UPC).
  item_code       String   @unique

  /// Human-readable description of the item.
  description     String

  /// Current price of the item.
  price           Float

  /// Optional department identifier.
  department_id   String?

  /// Timestamp of the last update.
  updated_at      DateTime @updatedAt

  /// Timestamp of when this item was first created.
  created_at      DateTime @default(now())

  @@map("items")
}

/// Represents a completed sale transaction.
model Sale {
  /// UUID primary key.
  id              String   @id @default(uuid())

  /// Unique transaction ID from the POS system.
  transaction_id  String   @unique

  /// When the transaction occurred.
  timestamp       DateTime

  /// Pre-tax total.
  total           Float

  /// Tax amount.
  tax             Float

  /// Final total with tax.
  grand_total     Float

  /// Method of payment (e.g., Cash, Credit Card).
  payment_type    String

  /// List of items included in this sale.
  items           SaleItem[]

  /// Timestamp of when this record was ingested.
  created_at      DateTime @default(now())

  @@map("sales")
}

/// Represents a single line item within a sale.
model SaleItem {
  /// UUID primary key.
  id              String   @id @default(uuid())

  /// Reference to the parent sale.
  sale_id         String
  sale            Sale     @relation(fields: [sale_id], references: [id], onDelete: Cascade)

  /// Stock Keeping Unit or product code.
  sku             String

  /// Name of the product at the time of sale.
  name            String

  /// Number of units sold.
  quantity        Int

  /// Unit price at the time of sale.
  price           Float

  @@map("sale_items")
}
